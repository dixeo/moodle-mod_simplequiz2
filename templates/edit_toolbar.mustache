{{!
    @template mod_simplequiz2/edit_toolbar
    @copyright 2026 Dixeo (contact@dixeo.com)

    Icon toolbar for one question on the activity edit form.

    Context variables:
    * questionid - Question index
    * buttons - array of button contexts for edit_toolbar_button partial
}}
<div class="simplequiz2-edit-toolbar" data-questionid="{{questionid}}">
    {{#buttons}}
        {{> mod_simplequiz2/edit_toolbar_button }}
    {{/buttons}}
</div>
