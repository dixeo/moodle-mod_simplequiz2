{{!
    @template mod_simplequiz2/edit_toolbar_button
    @copyright 2026 Dixeo (contact@dixeo.com)

    Single toolbar button on the activity edit form.

    Context variables:
    * class - CSS classes for the button
    * icon - Font Awesome icon class (without fa prefix)
    * label - Accessible label and tooltip
    * questionid - Question index
    * hidden - bool
    * showlabel - bool
    * icononly - bool
    * attrs - optional array of {name, value} extra attributes
}}
<button type="button" class="btn simplequiz2-toolbar-btn {{class}}{{#icononly}} simplequiz2-toolbar-btn--icon-only{{/icononly}}" title="{{label}}" aria-label="{{label}}" data-questionid="{{questionid}}"{{#hidden}} hidden{{/hidden}}{{#attrs}} {{name}}="{{value}}"{{/attrs}}>
    <i class="icon fa {{icon}}" aria-hidden="true"></i>
    {{#showlabel}}<span class="simplequiz2-toolbar-btn__label">{{label}}</span>{{/showlabel}}
</button>
