{{!
    @template mod_simplequiz2/question_block_start
    @copyright 2026 Dixeo (contact@dixeo.com)

    Opening markup for one question block (heading, toolbar, summary, warnings).

    Context variables:
    * questionid - Question index
    * title - Visible question title
    * hascontent - Whether the slot has any stored content
    * summaryhtml - Rendered question summary HTML
    * buttons - Toolbar button contexts
    * errornotenough - Not enough answers error string
    * errornoright - No correct answer error string
}}
<div class="simplequiz2-question-block-start" data-simplequiz2-block-start="{{questionid}}" data-questionid="{{questionid}}">
    <div class="simplequiz2-question-chrome">
        <div class="simplequiz2-question-head">
            <h3 class="simplequiz2-question-title">{{title}}</h3>
        {{> mod_simplequiz2/edit_toolbar }}
    </div>
        <div class="simplequiz2-question-meta {{^hascontent}}d-none{{/hascontent}}" data-questionid="{{questionid}}" data-has-content="{{#hascontent}}1{{/hascontent}}{{^hascontent}}0{{/hascontent}}" hidden aria-hidden="true"></div>
        <div class="header-questiontext" data-questionid="{{questionid}}">
            {{{summaryhtml}}}
        </div>
        <div class="error_not_enough_answers alert alert-danger">{{errornotenough}}</div>
        <div class="error_no_right_answer alert alert-danger">{{errornoright}}</div>
    </div>
    <div class="simplequiz2-question-editors d-none">
