{{!
    @template mod_simplequiz2/question_container

    Container for one question of simple quiz

    Classes required for JS:
    * none

    Data attributes required for JS:
    * none

    Context variables required for this template:
    * order question order
    * text  HTML of question text
    * answers array of answers
    * islast bool true if current question is the last of the simplequiz

    Example context (json):
    {
        "order": 1,
        "rank": 1,
        "text": "<p>Question text</p>",
        "islast": false,
        "answers": [
            {"order": 0, "text": "First answer"},
            {"order": 1, "text": "Second answer"}
        ]
    }
}}

<div class="question-container" data-questionid="{{order}}">
    <div class="question-text" tabindex="0">
        <span class="question-rank">{{#str}}question, simplequiz2{{/str}} {{rank}}</span> {{{text}}}
    </div>
    <div class="answers">
        {{#answers}}
            <button type="button" class="answer-container" data-answerid="{{order}}" tabindex="0">
                <span class="answer-text">{{{text}}}</span>
            </button>
        {{/answers}}
    </div>
    <div class="text-center">
        <div class="question-status" data-questionid="{{order}}"></div>
        <div class="question-feedback" data-questionid="{{order}}" hidden></div>
        <button class="check-answer" data-questionid="{{order}}" tabindex="0" aria-label="{{#str}} check-answer, simplequiz2{{/str}}">
            {{#str}}check-answer, simplequiz2{{/str}}
        </button>

        {{#islast}}
            <button class="show-results" data-questionid="{{order}}" tabindex="0">{{#str}} show-results, simplequiz2{{/str}}</button>
        {{/islast}}

        {{^islast}}
            <button class="next-question" data-questionid="{{order}}" tabindex="0">{{#str}} nextquestion, simplequiz2{{/str}}</button>
        {{/islast}}
    </div>
</div>