{{!
    @template mod_simplequiz2/question_summary
    @copyright 2026 Dixeo (contact@dixeo.com)

    Structured view-mode summary for one question on the activity edit form.

    Context variables:
    * hasquestion - bool
    * questiontext - raw HTML
    * hasanswers - bool
    * answerheading - string
    * answers - array of {text, iscorrect}
    * hasfeedback - bool
    * feedbackheading - string
    * feedbackitems - array of {label, text}
}}
{{#hasquestion}}
<div class="simplequiz2-summary-question"><strong>{{{questiontext}}}</strong></div>
{{/hasquestion}}
{{#hasanswers}}
<div class="simplequiz2-summary-section simplequiz2-summary-answers">
    <div class="simplequiz2-summary-heading"><strong>{{answerheading}}</strong></div>
    <ul class="simplequiz2-summary-list">
        {{#answers}}
        <li class="simplequiz2-summary-answer">
            {{#iscorrect}}<span class="simplequiz2-summary-check" aria-hidden="true">✓</span> {{/iscorrect}}{{{text}}}
        </li>
        {{/answers}}
    </ul>
</div>
{{/hasanswers}}
{{#hasfeedback}}
<div class="simplequiz2-summary-section simplequiz2-summary-feedbacks">
    <div class="simplequiz2-summary-heading"><strong>{{feedbackheading}}</strong></div>
    <ul class="simplequiz2-summary-list">
        {{#feedbackitems}}
        <li class="simplequiz2-summary-feedback-item"><strong>{{label}}:</strong> {{{text}}}</li>
        {{/feedbackitems}}
    </ul>
</div>
{{/hasfeedback}}
